# Copy to .env if you need to override defaults. Both are optional —
# the backend works with zero env vars if your project root layout
# matches the standard module1_pipeline ... module6_optimizer convention.

# Only needed if backend/ does NOT sit as a direct sibling of
# module1_pipeline/, module2_impact_score/, etc.
# INTELLIPARK_ROOT=/absolute/path/to/your/project/root

# Comma-separated list of frontend origins allowed to call this API.
# Defaults already cover the Vite dev server (5173) and a static
# preview server (4173).
# INTELLIPARK_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
